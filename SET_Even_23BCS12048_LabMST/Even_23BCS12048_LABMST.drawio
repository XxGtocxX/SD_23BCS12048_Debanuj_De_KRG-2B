        <mxCell id="NRdIkYyu0jA6Rm0OKIPd-1" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;Design&amp;nbsp; a Hotstar like applicaiton with following requirements:&lt;/font&gt;" vertex="1">
