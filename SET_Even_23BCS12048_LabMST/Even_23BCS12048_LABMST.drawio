        <mxCell id="NRdIkYyu0jA6Rm0OKIPd-2" parent="1" style="whiteSpace=wrap;html=1;align=left;" value="&lt;ul&gt;&lt;li&gt;User login Service&lt;/li&gt;&lt;li&gt;Subscriber Service&lt;/li&gt;&lt;li&gt;Movie / TV Show search Service&lt;/li&gt;&lt;li&gt;Movie / TV show Play Service&lt;/li&gt;&lt;/ul&gt;" vertex="1">
